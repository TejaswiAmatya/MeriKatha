# Copy to .env and fill real values before running docker compose.

# Backend runtime
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
JWT_SECRET=replace-with-a-long-random-secret
# Comma-separated allowed origins for CORS, e.g. https://app.vercel.app,https://www.yourdomain.com
CLIENT_URL=http://localhost:8080
# Cross-domain auth cookies in production should typically be:
# COOKIE_SAMESITE=none
# COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
COOKIE_DOMAIN=
GROQ_API_KEY=

# Frontend build-time public API URL
VITE_API_URL=http://localhost:3001
