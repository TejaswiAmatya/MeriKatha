// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  memberships  CircleMember[]
  stories      Story[]
}

model Circle {
  id            String         @id @default(cuid())
  slug          String         @unique
  circleId      String         @unique
  name          String
  nepaliName    String
  themeAffinity String
  memberCount   Int            @default(0)
  createdAt     DateTime       @default(now())
  members       CircleMember[]
}

model CircleMember {
  userId   String
  circleId String
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  circle   Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@id([userId, circleId])
}

model Story {
  id          String    @id @default(cuid())
  content     String
  audioBase64 String?                         // base64-encoded audio (webm/ogg, max 2min)
  isAnonymous Boolean   @default(true)
  status      String    @default("APPROVED") // APPROVED | DELETED
  flagCode    String?                         // CRISIS_CONTENT | ABUSIVE_CONTENT
  theme       String    @default("general")
  circleId    String    @default("SathiCircle")
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  suneinCount Int       @default(0)
  createdAt   DateTime  @default(now())
  comments    Comment[]
}

model Comment {
  id          String    @id @default(cuid())
  content     String
  isAnonymous Boolean   @default(true)
  storyId     String
  parentId    String?
  likeCount   Int       @default(0)
  suneinCount Int       @default(0)
  story       Story     @relation(fields: [storyId], references: [id], onDelete: Cascade)
  parent      Comment?  @relation("Replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[] @relation("Replies")
  createdAt   DateTime  @default(now())
}
