{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "prisma.config.ts",
    "index.ts",
    "config/**/*",
    "routes/**/*",
    "controller/**/*",
    "controllers/**/*",
    "middleware/**/*",
    "schema/**/*",
    "lib/**/*",
    "generated/**/*",
    "types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "files": [
    "types/express.d.ts"
  ]
}
